import sys
import time
from rich.panel import Panel


def slow_print(text, speed=0.010):
    for char in text:
        sys.stdout.write(char)
        sys.stdout.flush()
        if char == '.' or char == '!' or char == '?':
            time.sleep(0.15)
        elif char == ',' or char == ':' or char == ';':
            time.sleep(0.08)
        else:
            time.sleep(speed)
    print()
