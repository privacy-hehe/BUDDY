def get_robot_face(mood="neutral", color="green"):
    faces = {}
    faces["neutral"] = "[ o_o ]"
    faces["happy"] = "[ ^_^ ]"
    faces["think"] = "[ -_- ]"
    faces["shock"] = "[ O_O ]"
    faces["error"] = "[ x_x ]"
    if mood in faces:
        face = faces[mood]
    else:
        face = faces["neutral"]
    return f"""[bold {color}]
   _..._ 
  {face}
   =>B<= 
  /|   |\\
 (_|___|_)
[/bold {color}]"""


